{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_doc": "Youtube-Downloader project settings; copied from dev-guidelines v3.4.3 template. Attribution intentionally empty (no AI marks). See CLAUDE.md 規則實現層級對照 for rationale.",
  "attribution": {
    "commit": "",
    "pr": ""
  },

  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(mise ls*)",
      "Bash(mise current*)",
      "Bash(pre-commit run*)",
      "Read(**/*.md)",
      "Read(**/package.json)",
      "Read(**/package-lock.json)",
      "Read(**/tsconfig.json)",
      "Read(**/tsconfig.*.json)",
      "Read(**/.prettierrc)",
      "Read(**/.prettierrc.json)",
      "Read(**/.eslintrc*)",
      "Read(.claude/settings.json)",
      "Read(**/*.yaml)",
      "Read(**/*.yml)",
      "Read(**/*.toml)"
    ],
    "ask": ["Bash(curl *)", "Bash(wget *)"],
    "deny": [
      "Bash(sudo *)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push --force-if-includes*)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git push *--force*)",
      "Bash(git push *--force-with-lease*)",
      "Bash(git push *--force-if-includes*)",
      "Bash(git push *-f)",
      "Bash(git push *-f *)",
      "Read(/.env)",
      "Read(/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/token.json)",
      "Read(/.claude/settings.local.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Agent(manager)"
    ]
  }
}
