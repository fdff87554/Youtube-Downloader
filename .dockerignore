# Version control
**/.git
**/.gitignore
**/.gitattributes

# Node
**/node_modules
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Frontend build output (rebuilt inside the image)
frontend/dist

# Python
**/__pycache__
**/*.py[cod]
**/*.egg-info
**/.venv
**/venv
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache

# Tests and dev artefacts not needed at runtime
**/htmlcov
**/.coverage
**/.coverage.*

# Local env and secrets
**/.env
**/.env.*
!**/.env.example

# Editor / IDE
**/.vscode
**/.idea
**/*.swp
**/*.swo

# OS
**/.DS_Store
**/Thumbs.db

# Project-only docs and tooling that should not enter the image
.claude
CLAUDE.md
.codex
docs

# CI / repo metadata not needed at runtime
.github
.pre-commit-config.yaml
mise.toml
.python-version
.nvmrc
